{
  "name": "klick",
  "version": "0.1.0",
  "description": "Klick — open-source screen demo editor with cursor-aware zoom",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run build:native && electron-vite dev",
    "start": "electron-vite preview",
    "build:native": "bash native/build.sh",
    "build": "npm run build:native && electron-vite build && electron-builder --mac --dir",
    "dist": "npm run build:native && electron-vite build && electron-builder --mac",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "build": {
    "appId": "com.klick.app",
    "productName": "Klick",
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out/native/klick-capture",
        "to": "native/klick-capture"
      }
    ]
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uiohook-napi": "^1.5.5",
    "zustand": "^5.0.13"
  }
}
